 }
 
 func Value(name string) string {
-	return godebug.New(name).Value()
+	v := godebug.New(name).Value()
+	// When fips140=auto is set, check host FIPS mode and resolve to
+	// "on" if enabled, or "" (off) if not.
+	if name == "#fips140" && v == "auto" {
